{
  "name": "agent-rtc",
  "version": "0.4.1",
  "description": "Real-time communication for inter-agent messaging via Redis Streams. MCP server for Claude Code.",
  "type": "module",
  "bin": {
    "agent-rtc": "dist/redis-channel.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.mcp.json",
    "prepublishOnly": "npm run build",
    "start": "node dist/redis-channel.js",
    "lint:root": "eslint .",
    "lint:console": "npm --prefix console run lint",
    "lint": "npm run lint:root && npm run lint:console",
    "typecheck:root": "tsc --noEmit -p tsconfig.mcp.json",
    "typecheck:console": "npm --prefix console run typecheck",
    "typecheck": "npm run typecheck:root && npm run typecheck:console",
    "prepare": "husky"
  },
  "keywords": [
    "mcp",
    "claude",
    "agent",
    "rtc",
    "redis",
    "streams",
    "inter-agent",
    "messaging"
  ],
  "author": "yoooonghyun",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/yoooonghyun/agent-rtc.git"
  },
  "homepage": "https://github.com/yoooonghyun/agent-rtc",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ioredis": "^5.10.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^25.6.0",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.20.0"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --max-warnings=0"
    ],
    "console/**/*.{ts,tsx}": [
      "bash -c 'cd console && eslint --max-warnings=0 \"$@\"' --"
    ]
  }
}
